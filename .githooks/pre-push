#!/usr/bin/env bash
# pre-push hook — adversarial code review + dynamic QA gate
# Works on any git repo. Requires: claude CLI in PATH.
# Install: git config core.hooksPath .githooks
# Bypass (emergency): git push --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPTS_DIR="${PRE_PUSH_SCRIPTS_DIR:-$REPO_ROOT/scripts}"

# Fall back to looking for scripts next to this hook file
if [[ ! -f "$SCRIPTS_DIR/review-agent.sh" ]]; then
  HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  SCRIPTS_DIR="$(dirname "$HOOK_DIR")/scripts"
fi

if [[ ! -f "$SCRIPTS_DIR/review-agent.sh" ]]; then
  echo "⚠️  pre-push: cannot find review-agent.sh — skipping gate (set PRE_PUSH_SCRIPTS_DIR)" >&2
  exit 0
fi

MAX_LOOPS=3
LOOP=0

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

echo ""
echo -e "${BOLD}🔍 Pre-Push Gate${NC}"
echo -e "${CYAN}Code review + QA running...${NC}"
echo ""

DIFF_FILE=$(mktemp /tmp/prepush-diff.XXXXXX)
REVIEW_OUT=$(mktemp /tmp/prepush-review.XXXXXX)
QA_OUT=$(mktemp /tmp/prepush-qa.XXXXXX)
ISSUES_FILE=$(mktemp /tmp/prepush-issues.XXXXXX)

cleanup() { rm -f "$DIFF_FILE" "$REVIEW_OUT" "$QA_OUT" "$ISSUES_FILE"; }
trap cleanup EXIT

# Determine diff base from git's stdin
DIFF_BASE="HEAD~1"
while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    DIFF_BASE="origin/$(git remote show origin 2>/dev/null | grep 'HEAD branch' | awk '{print $NF}' || echo main)"
  else
    DIFF_BASE="$remote_sha"
  fi
done

git diff "${DIFF_BASE}...HEAD" > "$DIFF_FILE" 2>/dev/null \
  || git diff HEAD~1 > "$DIFF_FILE" 2>/dev/null \
  || true

DIFF_SIZE=$(wc -c < "$DIFF_FILE" | tr -d ' ')
if [[ "$DIFF_SIZE" -lt 20 ]]; then
  echo -e "${GREEN}✅ Nothing to review${NC}"
  exit 0
fi

echo -e "  Diff: ${DIFF_SIZE} bytes"
echo ""

while [[ $LOOP -lt $MAX_LOOPS ]]; do
  LOOP=$((LOOP + 1))
  echo -e "${BOLD}─── Round $LOOP / $MAX_LOOPS ───${NC}"

  # Refresh diff
  git diff "${DIFF_BASE}...HEAD" > "$DIFF_FILE" 2>/dev/null \
    || git diff HEAD~1 > "$DIFF_FILE" 2>/dev/null || true

  # Run both in parallel
  echo -e "  ${CYAN}⟳ Running review + QA in parallel...${NC}"
  "$SCRIPTS_DIR/review-agent.sh" "$REPO_ROOT" "$DIFF_FILE" "$REVIEW_OUT" &
  REVIEW_PID=$!
  "$SCRIPTS_DIR/qa-agent.sh" "$REPO_ROOT" "$DIFF_FILE" "$QA_OUT" &
  QA_PID=$!

  REVIEW_EXIT=0; QA_EXIT=0
  wait $REVIEW_PID || REVIEW_EXIT=$?
  wait $QA_PID    || QA_EXIT=$?

  echo ""

  # ── Code Review Results ──
  echo -e "${BOLD}📋 Code Review:${NC}"
  if ! grep -q "## VERDICT" "$REVIEW_OUT" 2>/dev/null; then
    echo -e "  ${RED}⚠️  Review agent output malformed — failing safe${NC}"
    head -5 "$REVIEW_OUT" | sed 's/^/    /'
    exit 1
  fi

  BLOCKING=$(awk '/## BLOCKING ISSUES/{p=1;next} /## NITPICKS/{p=0} p' "$REVIEW_OUT" | grep -v "^$" | head -25)
  NITPICKS=$(awk '/## NITPICKS/{p=1;next} /## VERDICT/{p=0} p' "$REVIEW_OUT" | grep -v "^$" | head -15)

  if [[ -n "$NITPICKS" && "$NITPICKS" != "None" ]]; then
    echo -e "  ${YELLOW}💬 Nitpicks (non-blocking):${NC}"
    echo "$NITPICKS" | sed 's/^/    /'
    echo ""
  fi

  if [[ $REVIEW_EXIT -ne 0 && -n "$BLOCKING" && "$BLOCKING" != "None" ]]; then
    echo -e "  ${RED}🚫 Blocking issues:${NC}"
    echo "$BLOCKING" | sed 's/^/    /'
  else
    REVIEW_EXIT=0
    echo -e "  ${GREEN}✅ No blocking issues${NC}"
  fi

  # ── QA Results ──
  echo ""
  echo -e "${BOLD}🧪 QA / Tests:${NC}"
  grep -E "✅|❌|⚠️|VERDICT" "$QA_OUT" 2>/dev/null | sed 's/^/  /' | head -20

  echo ""

  # ── Gate Decision ──
  if [[ $REVIEW_EXIT -eq 0 && $QA_EXIT -eq 0 ]]; then
    echo -e "${GREEN}${BOLD}✅ GATE PASSED${NC}"
    echo ""
    exit 0
  fi

  echo -e "${RED}${BOLD}⛔ GATE FAILED${NC}"
  [[ $REVIEW_EXIT -ne 0 ]] && echo -e "  ${RED}• Review: blocking issues${NC}"
  [[ $QA_EXIT -ne 0 ]]     && echo -e "  ${RED}• QA: test failures${NC}"
  echo ""

  if [[ $LOOP -ge $MAX_LOOPS ]]; then
    echo -e "${RED}Max fix rounds ($MAX_LOOPS) reached.${NC}"
    echo -e "${YELLOW}Fix manually and re-push. Bypass: git push --no-verify${NC}"
    echo ""
    exit 1
  fi

  # ── Auto-Fix Round ──
  echo -e "${CYAN}⟳ Auto-fix attempt $LOOP / $((MAX_LOOPS - 1))...${NC}"
  echo ""

  { echo "=== CODE REVIEW ==="; cat "$REVIEW_OUT"
    echo ""; echo "=== QA OUTPUT ==="; cat "$QA_OUT"; } > "$ISSUES_FILE"

  claude --permission-mode bypassPermissions --print "
Fix the blocking issues found by the code reviewer and QA agent.
Edit files directly. Do NOT run git commands, do NOT stage or commit.
Make the minimal changes to resolve each blocking issue.

Repo: $REPO_ROOT
Stack: $(cd "$REPO_ROOT" && { [[ -f package.json ]] && echo "Node/TS"; [[ -f go.mod ]] && echo "Go"; [[ -f Cargo.toml ]] && echo "Rust"; [[ -f pyproject.toml ]] && echo "Python"; } 2>/dev/null)

Issues to fix:
$(cat "$ISSUES_FILE")

Diff being pushed:
$(cat "$DIFF_FILE" | head -3000)
" 2>&1 | sed 's/^/  /'

  echo ""
  echo -e "${YELLOW}Auto-fix applied. Review with: git diff${NC}"
  echo -e "${YELLOW}Stage fixes, amend your commit, and re-push.${NC}"
  echo ""
  exit 1
done

exit 1
