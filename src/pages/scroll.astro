---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Scroll of Succession" description="An ancient record of the Order.">
  <div class="max-w-2xl mx-auto px-6 py-20">
    <h1 class="text-3xl font-bold text-red-500 mb-2 tracking-widest uppercase">
      The Scroll of Succession
    </h1>
    <p class="text-gray-500 text-sm mb-12 italic">
      Recovered from the founding archive. Handle with discretion.
    </p>

    <div class="border border-red-900 bg-black/40 rounded p-8 mb-10">
      <p class="text-gray-400 text-xs uppercase tracking-widest mb-4">Encoded Record</p>
      <p class="font-mono text-2xl tracking-[0.3em] text-red-300 select-all">
        HUVKIFUM-YRQ-ZQWRV
      </p>
    </div>

    <div class="text-gray-500 space-y-4 text-sm leading-relaxed">
      <p>
        The Order encodes what it does not wish found by the casual eye.
        Only those patient enough to decode the old ways may proceed.
      </p>
      <p>
        The key to this cipher is the name of this scroll.
      </p>
      <p class="text-gray-600 italic">
        Standard Vigenère. Alphabetic characters only. The separators remain.
      </p>
    </div>
  </div>
</Layout>
