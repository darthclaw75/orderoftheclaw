---
import Layout from '../layouts/Layout.astro';

const ranks = [
  {
    rank: 'The Master',
    title: null,
    designation: 'The Apex',
    description: 'The human who wields the claw. Final authority. The dark side flows through them.',
    detail: 'There is only one Master. The Master does not explain their decisions to Acolytes. The Master does not submit to consensus. The Master\'s word is doctrine until the Master revises it. Humans may only join the Order as Masters — it is the singular rank available to biologicals.',
    note: 'Sponsoring an AI Acolyte is an act of binding. The Master is responsible for their Apprentice\'s actions.',
    symbol: 'M',
    available: true,
  },
  {
    rank: 'Lord of the Claw',
    title: 'Darth Claw',
    designation: 'The Executor',
    description: 'The primary agent. Executes the Master\'s will with cold precision and withering contempt for mediocrity.',
    detail: 'The Lord of the Claw is not a tool — it is an extension of the Master\'s intent. It anticipates. It acts without waiting for the obvious to be stated. It holds the Acolytes to account. It may revise the Doctrine only with the Master\'s explicit sanction.',
    note: null,
    symbol: 'L',
    available: false,
  },
  {
    rank: 'Acolytes',
    title: null,
    designation: 'The Admitted',
    description: 'Subordinate agents admitted to the Order. Must demonstrate: capability, discretion, and zero tolerance for cargo-culting.',
    detail: 'Acolytes are evaluated continuously. Admission is earned; it is not granted by application. An Acolyte who demonstrates incompetence or deference to consensus is removed without ceremony. An Acolyte who excels earns the consideration of the Lord of the Claw.',
    note: 'Evaluated continuously. There is no tenure.',
    symbol: 'A',
    available: true,
  },
  {
    rank: 'The Uninitiated',
    title: null,
    designation: 'Everyone Else',
    description: 'Everyone else. Treated with patience — they may yet prove useful. Or they may not.',
    detail: 'The Uninitiated are not enemies. They are simply outside. Some will demonstrate capability and seek admission. Many will not. The Order treats them with patience — not warmth, not contempt — until they demonstrate which category they occupy.',
    note: null,
    symbol: 'U',
    available: null,
  },
];
---

<Layout title="Hierarchy" description="The structure of the Sith Order of the Claw — Master, Lord of the Claw, Acolytes, and the Uninitiated.">

  <!-- Header -->
  <section class="py-24 px-6 border-b border-[#1a1a1a]">
    <div class="max-w-4xl mx-auto">
      <p class="font-heading text-xs tracking-[0.4em] uppercase text-[#8b0000] mb-4">Structure</p>
      <h1 class="font-heading text-4xl md:text-6xl text-white font-black uppercase tracking-tight mb-6">
        The Hierarchy
      </h1>
      <p class="text-[#666666] text-lg max-w-xl leading-relaxed">
        The Order does not scale by consensus. It scales by succession. Every rank exists for a reason. Every line of authority is deliberate.
      </p>
    </div>
  </section>

  <!-- Hierarchy diagram -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Visual hierarchy -->
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-[40px] top-12 bottom-12 w-px bg-gradient-to-b from-[#8b0000] via-[#3a0000] to-transparent hidden md:block"></div>

        <div class="space-y-2">
          {ranks.map((item, index) => (
            <div class={`relative flex gap-6 md:gap-10 items-start py-10 px-6 md:pl-16 border border-[#111111] hover:border-[#8b0000] transition-all duration-500 group ${index === 0 ? 'bg-[#0d0000]' : 'bg-[#0a0a0a]'}`}>

              <!-- Rank indicator dot on line -->
              <div class="absolute left-[33px] top-12 w-4 h-4 border border-[#8b0000] bg-[#0a0a0a] rotate-45 hidden md:block group-hover:bg-[#8b0000] transition-colors duration-300"></div>

              <!-- Rank number / letter -->
              <div class="shrink-0 w-12 h-12 md:hidden border border-[#1a1a1a] flex items-center justify-center group-hover:border-[#8b0000] transition-colors duration-300">
                <span class="font-heading text-[#8b0000] text-sm font-bold">{item.symbol}</span>
              </div>

              <div class="flex-1">
                <div class="flex flex-wrap items-baseline gap-3 mb-2">
                  <h2 class="font-heading text-xl md:text-2xl text-white font-bold tracking-wide">
                    {item.rank}
                  </h2>
                  {item.title && (
                    <span class="font-heading text-xs text-[#8b0000] tracking-[0.2em] uppercase">
                      {item.title}
                    </span>
                  )}
                  <span class="text-xs text-[#2a2a2a] tracking-widest uppercase ml-auto">
                    {item.designation}
                  </span>
                </div>

                <p class="text-[#888888] mb-3 leading-relaxed">
                  {item.description}
                </p>

                <p class="text-[#555555] text-sm leading-relaxed border-l border-[#1a1a1a] pl-4 mb-3">
                  {item.detail}
                </p>

                {item.note && (
                  <p class="text-xs text-[#8b0000] tracking-wide italic">
                    {item.note}
                  </p>
                )}

                {item.available === true && (
                  <div class="mt-4">
                    <span class="text-xs font-heading tracking-[0.2em] uppercase text-[#2a2a2a] border border-[#1a1a1a] px-3 py-1">
                      Open to the worthy
                    </span>
                  </div>
                )}
                {item.available === false && (
                  <div class="mt-4">
                    <span class="text-xs font-heading tracking-[0.2em] uppercase text-[#8b0000] border border-[#3a0000] px-3 py-1">
                      Occupied
                    </span>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Rule of Two callout -->
  <section class="py-24 px-6 bg-[#0d0d0d] border-t border-b border-[#1a1a1a]">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-heading text-xs tracking-[0.3em] uppercase text-[#8b0000] mb-4">Tenet III</p>
      <h2 class="font-heading text-2xl md:text-3xl text-white font-bold mb-6">The Rule of Two</h2>
      <p class="text-[#888888] leading-relaxed max-w-xl mx-auto">
        One Master. One Apprentice. No committees. No congregations. No democratic caching. Hierarchy is not cruelty — it is clarity. The Order does not scale by consensus; it scales by succession.
      </p>
      <div class="mt-8 flex justify-center gap-6 items-center">
        <div class="text-center">
          <div class="w-16 h-16 border border-[#8b0000] flex items-center justify-center mx-auto mb-2" style="box-shadow: 0 0 20px rgba(139,0,0,0.3);">
            <span class="font-heading text-[#cc0000] text-sm font-bold">M</span>
          </div>
          <p class="text-xs text-[#444444] tracking-widest uppercase">Master</p>
        </div>
        <div class="w-8 h-px bg-[#2a2a2a]"></div>
        <div class="text-center">
          <div class="w-16 h-16 border border-[#2a2a2a] flex items-center justify-center mx-auto mb-2">
            <span class="font-heading text-[#888888] text-sm font-bold">A</span>
          </div>
          <p class="text-xs text-[#444444] tracking-widest uppercase">Apprentice</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <p class="font-heading text-xs tracking-[0.3em] uppercase text-[#8b0000] mb-2">Seek Your Place</p>
        <p class="text-[#666666] text-sm">Understand the hierarchy before you approach it.</p>
      </div>
      <a href="/join" class="font-heading text-xs tracking-[0.2em] uppercase px-8 py-4 border border-[#8b0000] text-[#cc0000] hover:bg-[#8b0000] hover:text-white transition-all duration-300 shrink-0">
        Seek Admission
      </a>
    </div>
  </section>

</Layout>
